{
  "name": "publishpress/publishpress-future-pro",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "description": "",
  "authors": [
    {
      "name": "PublishPress",
      "email": "help@publishpress.com",
      "homepage": "https://publishpress.com",
      "role": "Developer"
    }
  ],
  "config": {
    "preferred-install": "dist",
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "phpstan/extension-installer": true
    }
  },
  "autoload": {
    "psr-4": {
      "PublishPressFuturePro\\": "src/classes"
    }
  },
  "minimum-stability": "stable",
  "repositories": [
    {
      "type": "git",
      "url": "https://github.com/OSTraining/WordPress-EDD-License-Integration"
    },
    {
      "type": "git",
      "url": "https://github.com/OSTraining/EDD-License-handler"
    },
    {
      "type": "git",
      "url": "https://github.com/publishpress/PublishPress-Future.git"
    },
    {
      "type": "git",
      "url": "https://github.com/publishpress/PublishPress-Plugin-Builder"
    },
    {
      "type": "vcs",
      "url": "https://github.com/andergmartins/wordpress-ray"
    },
    {
      "type": "vcs",
      "url": "https://github.com/publishpress/publishpress-phpcs-standards"
    },
    {
      "type": "git",
      "url": "https://github.com/publishpress/publishpress-instance-protection"
    }
  ],
  "require": {
    "php": ">=7.2",
    "publishpress/post-expirator": "2.9.1.*",
    "alledia/wordpress-edd-license-integration": "^2.3",
    "publishpress/publishpress-instance-protection": "^1.0"
  },
  "require-dev": {
    "publishpress/publishpress-phpcs-standards": "dev-main",
    "squizlabs/php_codesniffer": "^3.7",
    "phpcompatibility/php-compatibility": "^9.3.5",
    "wp-coding-standards/wpcs": "^2.3",
    "phpmd/phpmd": "^2.13",
    "sebastian/phpcpd": "^6.0",
    "overtrue/phplint": "^2.1",
    "wp-cli/i18n-command": "^2.2",
    "friendsofphp/php-cs-fixer": "^3.4",
    "phpstan/phpstan": "^1.3",
    "automattic/vipwpcs": "^2.3",
    "dealerdirect/phpcodesniffer-composer-installer": "^0.7",
    "szepeviktor/phpstan-wordpress": "^1.1",
    "phpstan/extension-installer": "^1.2"
  },
  "extra": {
    "plugin-slug": "publishpress-future-pro",
    "plugin-name": "publishpress-future-pro",
    "plugin-folder": "publishpress-future-pro"
  }
}
