{
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "vendor-dir": "vendor",
        "preferred-install": {
            "*": "dist"
        },
        "platform-check": false,
        "autoloader-suffix": "PublishPressFuturePro"
    },
    "autoload": {
        "psr-4": {
            "PublishPress\\FuturePro\\": "../src/classes"
        }
    },
    "require": {
        "ext-json": "*",
        "php": ">=7.2.5",
        "publishpress/instance-protection": "^1.0",
        "publishpress/pimple-pimple": "^3.5",
        "publishpress/psr-container": "^2.0",
        "publishpress/publishpress-future": "3.1.0",
        "publishpress/wordpress-banners": "^1.3",
        "publishpress/wordpress-reviews": "^1.1",
        "publishpress/wordpress-version-notices": "^2.1",
        "woocommerce/action-scheduler": "^3.5",
        "publishpress/wordpress-edd-license": "^3.0"
    },
    "scripts": {
        "check:deps": "checkdep . publishpress/publishpress-future",
        "fix:deps": "mergedep . publishpress/publishpress-future",
        "post-autoload-dump": "@check:deps",
        "post-update-cmd": "rm -rf vendor/publishpress/publishpress-future/lib/vendor",
        "post-install-cmd": "@post-update-cmd"
    }
}
