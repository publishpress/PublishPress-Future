#. Plugin Name of the plugin
#: publishpress-future-pro.php
msgid "PublishPress Future Pro"
msgstr "PublishPress Future Pro"

#. Plugin URI of the plugin
#: publishpress-future-pro.php
msgid "http://wordpress.org/extend/plugins/post-expirator/"
msgstr "http://wordpress.org/extend/plugins/post-expirator/"

#. Description of the plugin
#: publishpress-future-pro.php
msgid ""
"PublishPress Future allows you to schedule automatic changes to posts, pages "
"and other content types."
msgstr ""
"PublishPress Future vous permet de programmer des modifications automatiques "
"des publications, des pages et d’autres types de publication."

#. Author of the plugin
#: publishpress-future-pro.php
msgid "PublishPress"
msgstr "PublishPress"

#. Author URI of the plugin
#: publishpress-future-pro.php
msgid "http://publishpress.com"
msgstr "http://publishpress.com"

