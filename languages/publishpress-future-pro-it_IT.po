msgstr "Il nuovo stato dell'articolo da applicare all'articolo."

#: src/classes/Controllers/SettingsController.php:293
msgid "Action Status"
msgstr "Stato dell'azione"

#: src/classes/Controllers/SettingsController.php:294
msgid ""
"The status for the action. Anything different than 'saved' will be "
"considered as not active."
msgstr ""
"Lo stato dell'azione. Qualsiasi cosa diversa da \"salvato\" sarà considerata "
"non attivo."

#: src/classes/Controllers/SettingsController.php:302
msgid "Taxonomy Name"
msgstr "Nome della tassonomia"

#: src/classes/Controllers/SettingsController.php:303
msgid "The taxonomy used for scheduling the action."
msgstr "La tassonomia utilizzata per la programmazione dell'azione."

#: src/classes/Controllers/SettingsController.php:311
msgid "Taxonomy Terms"
msgstr "Termini della tassonomia"

#: src/classes/Controllers/SettingsController.php:312
msgid "The terms used for scheduling the action."
msgstr "I termini utilizzati per la programmazione dell'azione."

