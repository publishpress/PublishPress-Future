#: src/classes/Controllers/SettingsController.php:257
msgid "days"
msgstr ""

#: src/classes/Controllers/SettingsController.php:266
msgid "Action Date (Required)"
msgstr "Data dell'azione (obbligatoria)"

#: src/classes/Controllers/SettingsController.php:267
msgid ""
"The date used for scheduling the action. The date must be a unix time stamp "
"or in the 'Y-m-d H:i:s' format."
msgstr ""
"La data utilizzata per programmare l'azione. La data deve essere una marca "
"temporale unix o nel formato \"Y-m-d H:i:s\"."

