#. Plugin Name of the plugin
#: publishpress-future-pro.php
msgid "PublishPress Future Pro"
msgstr "PublishPress Future Pro"

#. Plugin URI of the plugin
#: publishpress-future-pro.php
msgid "http://wordpress.org/extend/plugins/post-expirator/"
msgstr "http://wordpress.org/extend/plugins/post-expirator/"

#. Description of the plugin
#: publishpress-future-pro.php
msgid ""
"PublishPress Future allows you to schedule automatic changes to posts, pages "
"and other content types."
msgstr ""
"PublishPress Future le permite programar cambios automáticos en "
"publicaciones, páginas y otros tipos de contenido."

#. Author of the plugin
#: publishpress-future-pro.php
msgid "PublishPress"
msgstr "PublishPress"

#. Author URI of the plugin
#: publishpress-future-pro.php
msgid "http://publishpress.com"
msgstr "http://publishpress.com"

#. Translators: Do not translate the #ACTIONDATE, or #ACTIONTIME placeholders.
#: src/classes/Controllers/BlocksController.php:47
msgid "Post expires at #ACTIONTIME on #ACTIONDATE."
msgstr "La entrada caduca a las #ACTIONTIME del #ACTIONDATE."

#: src/classes/Controllers/BlocksController.php:48
msgid "F j, Y"
msgstr "j F, Y"

#: src/classes/Controllers/BlocksController.php:49
msgid "g:i a"
msgstr "g:i a"

#: src/classes/Controllers/BlocksController.php:86
msgid "Displays a message with the date and time of the future action."
msgstr "Muestra un mensaje con la fecha y hora de la acción de future."

#: src/classes/Controllers/BlocksController.php:87
msgid ""
"Type the text template and use # to see the autocomplete options with the "
"available placeholders."
msgstr ""
"Introduce la plantilla de texto y utiliza # para ver las opciones de relleno "
"automático con los marcadores de posición disponibles."

#: src/classes/Controllers/BlocksController.php:88
msgid "Available placeholders"
msgstr "Marcadores de posición disponibles"

#: src/classes/Controllers/BlocksController.php:89
msgid ""
"Future action block template. Type the text and # to see the autocomplete "
"options."
msgstr ""
"Plantilla de bloque de acción de Future. Introduce el texto y # para ver las "
"opciones de relleno automático."

#: src/classes/Controllers/BlocksController.php:90
#| msgid "Activated"
msgid "Action time"
msgstr "Horario de acción"

#: src/classes/Controllers/BlocksController.php:91
msgid "Action date"
msgstr "Fecha de la acción"

#: src/classes/Controllers/SettingsController.php:196
msgid "Custom statuses"
msgstr "Estados personalizados"

#: src/classes/Controllers/SettingsController.php:197
msgid "Enable custom statuses for the post type."
msgstr "Activar los estados personalizados para el tipo de contenido."

#: src/classes/Controllers/SettingsController.php:201
msgid "Enabled"
msgstr "Activado"

#: src/classes/Controllers/SettingsController.php:202
msgid "Disabled"
msgstr "Desactivado"

#: src/classes/Controllers/SettingsController.php:203
msgid "Select all"
msgstr "Seleccionar todo"

#: src/classes/Controllers/SettingsController.php:204
msgid "Unselect all"
msgstr "Deseleccionar todo"

#: src/classes/Controllers/SettingsController.php:205
msgid "Enable Metadata Scheduling"
msgstr "Activar la programación de metadatos"

#: src/classes/Controllers/SettingsController.php:206
msgid "Enable metadata scheduling for the post type"
msgstr "Activar la programación de metadatos para el tipo de contenido:"

#: src/classes/Controllers/SettingsController.php:210
msgid ""
"Checking this option will allow you to use the post metadata to control the "
"scheduling of Future actions in your content."
msgstr ""
"Al marcar esta opción podrás utilizar los metadatos de la entrada para "
"controlar la programación de las acciones de Future en tu contenido."

#: src/classes/Controllers/SettingsController.php:214
msgid "Metadata Mapping"
msgstr "Asignación de metadatos"

#: src/classes/Controllers/SettingsController.php:215
msgid "To use the default mapping, please leave the fields empty."
msgstr ""
"Para utilizar la asignación por defecto, por favor, deja los campos vacíos."

#: src/classes/Controllers/SettingsController.php:219
msgid "Read more about metadata mapping."
msgstr "Más información sobre la asignación de metadatos."

#: src/classes/Controllers/SettingsController.php:224
msgid "Original Metakey"
msgstr "Metakey original"

#: src/classes/Controllers/SettingsController.php:225
msgid "New Metakey"
msgstr "Nueva metakey"

#: src/classes/Controllers/SettingsController.php:226
msgid "Description"
msgstr "Descripción"

#: src/classes/Controllers/SettingsController.php:227
#| msgid "Enable custom statuses for the post type:"
msgid "Hide Future metabox for this post type"
msgstr "Ocultar la caja meta de Future para este tipo de contenido"

#: src/classes/Controllers/SettingsController.php:228
msgid ""
"Checking this option will disable the PublishPress Future metabox. This can "
"prevent conflicts if you're using Metadata Scheduling with plugins such as "
"ACF or Pods."
msgstr ""
"Al marcar esta opción se desactivará la caja meta PublishPress Future. Esto "
"puede evitar conflictos si estás usando la programación de metadatos con "
"plugins como ACF o Pods."

#: src/classes/Controllers/SettingsController.php:240
msgid "Action Date (Required)"
msgstr "Fecha de la acción (obligatoria)"

#: src/classes/Controllers/SettingsController.php:241
msgid ""
"The date used for scheduling the action. The date must be a unix time stamp "
"or in the 'Y-m-d H:i:s' format."
msgstr ""
"La fecha utilizada para programar la acción. La fecha debe ser una marca de "
"tiempo unix o en el formato 'Y-m-d H:i:s'."

#: src/classes/Controllers/SettingsController.php:249
msgid "Action Type"
msgstr "Tipo de acción"

#: src/classes/Controllers/SettingsController.php:250
msgid "The type of action to be performed."
msgstr "El tipo de acción a realizar."

#: src/classes/Controllers/SettingsController.php:258
msgid "New Post Status"
msgstr "Nuevo estado de la entrada"

#: src/classes/Controllers/SettingsController.php:259
msgid "The new post status to be applied to the post."
msgstr "El nuevo estado de la entrada que se aplicará a la entrada."

#: src/classes/Controllers/SettingsController.php:267
msgid "Action Status"
msgstr "Estado de la acción"

#: src/classes/Controllers/SettingsController.php:268
msgid ""
"The status for the action. Anything different than 'saved' will be "
"considered as not active."
msgstr ""
"El estado de la acción. Todo lo que no sea «guardado» se considerará no "
"activo."

#: src/classes/Controllers/SettingsController.php:276
msgid "Taxonomy Name"
msgstr "Nombre de la taxonomía"

#: src/classes/Controllers/SettingsController.php:277
msgid "The taxonomy used for scheduling the action."
msgstr "La taxonomía utilizada para programar la acción."

#: src/classes/Controllers/SettingsController.php:285
msgid "Taxonomy Terms"
msgstr "Términos de la taxonomía"

#: src/classes/Controllers/SettingsController.php:286
msgid "The terms used for scheduling the action."
msgstr "Los términos utilizados para programar la acción."

#: src/classes/Controllers/SettingsController.php:345
msgid "Form Validation Failure: Sorry, your nonce did not verify."
msgstr ""
"Error en la validación del formulario: Lo sentimos, tu nonce no ha sido "
"verificado."

#: src/classes/Domain/ExpirationActions/PostStatusToCustomStatus.php:113
msgid "Change status to custom status"
msgstr "Cambiar el estado a estado personalizado"

#. translators: %s is the new post status
#: src/classes/Domain/ExpirationActions/PostStatusToCustomStatus.php:123
msgid "Change status to %s"
msgstr "Cambiar estado a %s"

#: src/templates/settings-tab-advanced.html.php:6
msgid "Action Date Calculation Base"
msgstr "Base de cálculo de la fecha de la acción"

#: src/templates/settings-tab-advanced.html.php:17
msgid "Use Current Date"
msgstr "Utilizar la fecha actual"

#: src/templates/settings-tab-advanced.html.php:19
msgid "Calculates the future action date based on today's date."
msgstr "Calcula la fecha de la acción de future basándose en la fecha de hoy."

#: src/templates/settings-tab-advanced.html.php:29
msgid "Use Post's Publish Date"
msgstr "Utilizar la fecha de publicación de la entrada"

#: src/templates/settings-tab-advanced.html.php:31
msgid ""
"Calculates the future action date from the post's original publish date."
msgstr ""
"Calcula la fecha de la acción de future basándose en la fecha de publicación "
"original de la entrada."

#: src/templates/settings-tab-license.html.php:11
#: src/templates/settings-tab-license.html.php:17
msgid "License"
msgstr "Licencia"

#: src/templates/settings-tab-license.html.php:35
msgid "Activated"
msgstr "Activado"

#: src/templates/settings-tab-license.html.php:37
msgid "Inactive"
